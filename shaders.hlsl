// ============================================================================
// НАСТРОЙКИ И ВХОДНЫЕ ДАННЫЕ ШЕЙДЕРА
// ============================================================================

// Константный буфер для передачи матриц трансформации из C++ кода.
// register(b0) жестко связывает его с первым параметром корневой сигнатуры.
cbuffer ConstantBuffer : register(b0)
{
    matrix wvpMatrix; // Объединенная матрица (World * View * Projection)
};

// Структура данных, поступающих ИЗ C++ кода (Vertex Buffer) В вершинный шейдер.
struct VSInput
{
    float3 position : POSITION; // Семантика POSITION привязана к Input Layout в C++
    float4 color    : COLOR;    // Семантика COLOR привязана к Input Layout в C++
};

// Структура данных, передаваемых ИЗ вершинного шейдера В пиксельный шейдер.
struct PSInput
{
    float4 position : SV_POSITION; // SV_ (System Value) указывает на системные экранные координаты
    float4 color    : COLOR;       // Сюда запишется цвет для интерполяции по пикселям
};

// ============================================================================
// ВЕРШИННЫЙ ШЕЙДЕР (VERTEX SHADER)
// ============================================================================
// Функция трансформирует каждую вершину 3D-куба в экранное пространство.
PSInput VSMain(VSInput input)
{
    PSInput output;

    // Переводим 3D координаты вершины (X, Y, Z) в однородные 4D координаты (X, Y, Z, W)
    float4 localPos = float4(input.position, 1.0f);

    // Умножаем позицию вершины на матрицу трансформации WVP.
    // Функция mul() выполняет умножение вектора на матрицу.
    output.position = mul(localPos, wvpMatrix);

    // Передаем цвет вершины без изменений в следующий этап конвейера
    output.color = input.color;

    return output;
}

// ============================================================================
// ПИКСЕЛЬНЫЙ ШЕЙДЕР (PIXEL SHADER)
// ============================================================================
// Функция красит каждый отдельный пиксель на грани куба.
float4 PSMain(PSInput input) : SV_TARGET
{
    // Возвращаем итоговый цвет пикселя. 
    // Видеокарта автоматически смешает (интерполирует) цвета между вершинами треугольника.
    return input.color;
}
